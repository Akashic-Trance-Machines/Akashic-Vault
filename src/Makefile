#
# Makefile — Akashic Vault
#
# Built against circle-stdlib (Akashic-Trance-Machines fork). Configure the stdlib
# per target first (scripts/build.sh does this), then this Makefile compiles the
# app and links the Circle + LVGL + FatFs libraries into kernel8.img /
# kernel8-rpi4.img.
#
# RASPPI is supplied by the build script (3 or 4); AARCH=64 throughout.
#

CIRCLE_STDLIB_DIR ?= ../circle-stdlib

AARCH    ?= 64
RASPPI   ?= 4
OPTIMIZE  = -O3
STANDARD  = -std=c++17
GC_SECTIONS = 1

# ── Application objects ───────────────────────────────────────────────────────
OBJS = \
	main.o \
	kernel.o \
	engine/cengine.o \
	engine/cmodrouter.o \
	engine/cmoduleregistry.o \
	engine/isoundgenerator.o \
	platform/ci2saudio.o \
	ui/c4rowmenu.o \
	ui/c4rowrenderer.o \
	ui/c4rowui.o \
	generated/modules_table.o

# ── AV-Plaits (Mutable Instruments macro oscillator, 24 engines) ─────────────
PLAITS_DIR = modules/generators/plaits
PLAITS_CORE = $(PLAITS_DIR)/core
OBJS += \
	$(PLAITS_DIR)/src/plaits_generator.o \
	$(PLAITS_CORE)/plaits/resources.o \
	$(PLAITS_CORE)/plaits/dsp/voice.o \
	$(PLAITS_CORE)/plaits/dsp/chords/chord_bank.o \
	$(PLAITS_CORE)/plaits/dsp/engine/additive_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/bass_drum_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/chord_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/fm_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/grain_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/hi_hat_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/modal_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/noise_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/particle_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/snare_drum_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/speech_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/string_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/swarm_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/virtual_analog_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/waveshaping_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine/wavetable_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine2/chiptune_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine2/phase_distortion_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine2/six_op_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine2/string_machine_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine2/virtual_analog_vcf_engine.o \
	$(PLAITS_CORE)/plaits/dsp/engine2/wave_terrain_engine.o \
	$(PLAITS_CORE)/plaits/dsp/fm/algorithms.o \
	$(PLAITS_CORE)/plaits/dsp/fm/dx_units.o \
	$(PLAITS_CORE)/plaits/dsp/physical_modelling/modal_voice.o \
	$(PLAITS_CORE)/plaits/dsp/physical_modelling/resonator.o \
	$(PLAITS_CORE)/plaits/dsp/physical_modelling/string.o \
	$(PLAITS_CORE)/plaits/dsp/physical_modelling/string_voice.o \
	$(PLAITS_CORE)/plaits/dsp/speech/lpc_speech_synth.o \
	$(PLAITS_CORE)/plaits/dsp/speech/lpc_speech_synth_controller.o \
	$(PLAITS_CORE)/plaits/dsp/speech/lpc_speech_synth_phonemes.o \
	$(PLAITS_CORE)/plaits/dsp/speech/lpc_speech_synth_words.o \
	$(PLAITS_CORE)/plaits/dsp/speech/naive_speech_synth.o \
	$(PLAITS_CORE)/plaits/dsp/speech/sam_speech_synth.o \
	$(PLAITS_CORE)/stmlib/dsp/atan.o \
	$(PLAITS_CORE)/stmlib/dsp/units.o \
	$(PLAITS_CORE)/stmlib/utils/random.o

# ── AV-CloudSeed (GhostNote algorithmic reverb, MIT core) ────────────────────
CLOUDSEED_DIR  = modules/audiofx/cloudseed
CLOUDSEED_CORE = $(CLOUDSEED_DIR)/core/CloudSeedCore
OBJS += \
	$(CLOUDSEED_DIR)/src/cloudseed_fx.o \
	$(CLOUDSEED_DIR)/src/presets.o \
	$(CLOUDSEED_CORE)/DSP/Biquad.o \
	$(CLOUDSEED_CORE)/DSP/FastSin.o \
	$(CLOUDSEED_CORE)/DSP/RandomBuffer.o \
	$(CLOUDSEED_CORE)/Parameters.o

# ── AV-YKChorus (TAL Juno-60 chorus, GPL-2.0 core, header-only) ──────────────
YKCHORUS_DIR = modules/audiofx/ykchorus
OBJS += \
	$(YKCHORUS_DIR)/src/ykchorus_fx.o

# ── AV-Arp (MIDI arpeggiator, original implementation, GPL-3.0) ─────────────
ARP_DIR = modules/midifx/arp
OBJS += \
	$(ARP_DIR)/src/arp_midifx.o

EXTRACLEAN = $(OBJS) $(OBJS:.o=.d)

# ── Version stamp ─────────────────────────────────────────────────────────────
DATE    := $(shell git log -1 --format=%cd --date=format:%y%m%d 2>/dev/null || echo 000000)
COMMIT  := $(shell git rev-parse --short HEAD 2>/dev/null || echo unknown)
VERSION := $(DATE)-$(COMMIT)
DEFINE  += -DVERSION=\"$(VERSION)\"
DEFINE  += -DARM_ALLOW_MULTI_CORE
# Plaits/stmlib: -DTEST selects portable C++ code paths (no ARMv7 Thumb-2 asm).
DEFINE  += -DTEST

# ── Pull in Circle's build config (generated by circle-stdlib ./configure) ────
include $(CIRCLE_STDLIB_DIR)/Config.mk

CIRCLEHOME = $(CIRCLE_STDLIB_DIR)/libs/circle
NEWLIBDIR  = $(CIRCLE_STDLIB_DIR)/install/$(NEWLIB_ARCH)
LVGLHOME   = $(CIRCLEHOME)/addon/lvgl

# Includes: app root, Circle addons (display/ssd1309display.h, gpio/mcp23017.h,
# lvgl/lvgl.h), LVGL itself, and newlib.
INCLUDE += -I . -I $(CIRCLEHOME)/addon -I $(LVGLHOME) -I $(LVGLHOME)/lvgl
INCLUDE += -I $(NEWLIBDIR)/include -I $(CIRCLE_STDLIB_DIR)/include
# Plaits/stmlib: include the vendored core root so `#include "plaits/..."` and
# `#include "stmlib/..."` resolve correctly.
INCLUDE += -I $(PLAITS_CORE) -I $(PLAITS_DIR)/src
# CloudSeed: core root + compat/ for <arm_math.h> stub on AArch64.
# Force-include cstdlib so std::rand in the core compiles without patching it.
INCLUDE += -I $(CLOUDSEED_CORE)/.. -I $(CLOUDSEED_DIR)/src -I $(CLOUDSEED_DIR)/core/compat
CFLAGS += -include cstdlib
# YKChorus: vendored core headers + src wrapper.
INCLUDE += -I $(YKCHORUS_DIR)/core -I $(YKCHORUS_DIR)/src
# AV-Arp: src wrapper only (original implementation, no vendored core).
INCLUDE += -I $(ARP_DIR)/src

# ── Libraries (order matters for the GNU linker) ──────────────────────────────
# NOTE: confirm the exact set/paths against the vendored circle-stdlib version.
LIBS = \
	$(LVGLHOME)/liblvgl.a \
	$(CIRCLEHOME)/addon/display/libdisplay.a \
	$(CIRCLEHOME)/addon/gpio/libgpio.a \
	$(CIRCLEHOME)/addon/sensor/libsensor.a \
	$(CIRCLEHOME)/addon/Properties/libproperties.a \
	$(CIRCLEHOME)/addon/fatfs/libfatfs.a \
	$(CIRCLEHOME)/lib/usb/libusb.a \
	$(CIRCLEHOME)/lib/input/libinput.a \
	$(CIRCLEHOME)/lib/fs/libfs.a \
	$(CIRCLEHOME)/lib/sched/libsched.a \
	$(CIRCLEHOME)/lib/sound/libsound.a \
	$(CIRCLEHOME)/addon/SDCard/libsdcard.a \
	$(CIRCLEHOME)/lib/libcircle.a

include $(CIRCLEHOME)/Rules.mk

# Newlib + stdc++ (provided by the circle-stdlib install tree).
LIBS += \
	$(NEWLIBDIR)/lib/libm.a \
	$(NEWLIBDIR)/lib/libc.a \
	$(NEWLIBDIR)/lib/libcirclenewlib.a

# ── Codegen: regenerate menu tables before compiling ──────────────────────────
.PHONY: gen
gen:
	python3 ../scripts/gen_menus.py --root ..

# 'make' depends on generated sources existing.
generated/modules_table.o: gen
